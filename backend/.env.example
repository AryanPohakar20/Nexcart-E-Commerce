# =============================================================
# NEXCART BACKEND — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit the .env file to version control.
# =============================================================

# ── Server ────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────────
# Get your free cluster at: https://cloud.mongodb.com
# Example: mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/nexcart?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/nexcart?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_replace_this_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_replace_this_in_production
ACCESS_TOKEN_EXPIRE=15m
REFRESH_TOKEN_EXPIRE=7d

# ── Email (Nodemailer / Gmail) ─────────────────────────────────
# Use a Gmail App Password (NOT your account password).
# Guide: https://support.google.com/accounts/answer/185833
EMAIL=your_gmail@gmail.com
EMAIL_PASSWORD=your_gmail_app_password

# ── Frontend URL (CORS Origin) ─────────────────────────────────
CLIENT_URL=http://localhost:5173
